generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model File {
  id             String   @id @default(cuid())
  name           String
  url            String
  size           Int
  content        String   // CSV version for AI
  originalBinary String?  // ✅ Base64 encoded original file for download
  fileType       String   @default("text/csv")
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}